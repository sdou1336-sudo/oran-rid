rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User Document Permissions
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Active Driver Locations
    match /active_drivers/{driverId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == driverId;
    }

    // Trip Requests - Core inDrive Bidding Security
    match /trips/{tripId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      
      // Allow updates if the user is the rider OR if the user is a vetted verified driver
      allow update: if request.auth != null && (
        resource.data.riderId == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isVerified == true
      );
      
      allow delete: if request.auth != null && resource.data.riderId == request.auth.uid;
    }
  }
}
